<Page
    x:Class="TicketSellingModule.WinUI.StaffPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TicketSellingModule.WinUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:components="using:TicketSellingModule.WinUI.Components"
    mc:Ignorable="d"
    Background="#1E1E1E">

    <Page.Resources>
        <SolidColorBrush x:Key="CustomAccentBrush" Color="#2bb8c0"/>
    </Page.Resources>

    <Grid Padding="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <components:Header Grid.Row="0"/>

        <Border Grid.Row="1"
                BorderBrush="#3F3F46"
                BorderThickness="1"
                CornerRadius="8"
                Background="#252526"
                Width="980"
                Height="620"
                HorizontalAlignment="Center"
                VerticalAlignment="Top">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="20,20,20,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="MY SCHEDULED FLIGHTS"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="White"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                            Content="Refresh"
                            Background="{StaticResource CustomAccentBrush}"
                            Foreground="White"
                            Padding="16,8"
                            CornerRadius="4"
                            Click="RefreshButton_Click"/>
                </Grid>

                <Grid Grid.Row="1" Margin="20,0,20,15" ColumnSpacing="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="8" Padding="15">
                        <StackPanel>
                            <TextBlock Text="EMPLOYEE ID" Foreground="#A0A0A0" FontSize="12"/>
                            <TextBlock x:Name="EmployeeIdText" Text="-" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="#1E1E1E" CornerRadius="8" Padding="15">
                        <StackPanel>
                            <TextBlock Text="ROLE" Foreground="#A0A0A0" FontSize="12"/>
                            <TextBlock x:Name="RoleText" Text="-" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="#1E1E1E" CornerRadius="8" Padding="15">
                        <StackPanel>
                            <TextBlock Text="ASSIGNED FLIGHTS" Foreground="#A0A0A0" FontSize="12"/>
                            <TextBlock x:Name="FlightsCountText" Text="0" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="2" Background="{StaticResource CustomAccentBrush}" Padding="15,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.6*"/>
                        <ColumnDefinition Width="1.4*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1.4*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="ID" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="FLIGHT NO." Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="TYPE" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="DATE" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="GATE" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="5" Text="RUNWAY" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="6" Text="TIME" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </Grid>

                <Grid Grid.Row="3">
                    <ListView x:Name="FlightScheduleList"
                              ItemsSource="{x:Bind ScheduledFlights, Mode=OneWay}"
                              Padding="0"
                              SelectionMode="None"
                              BorderThickness="0">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:EmployeeScheduleItem">
                                <Grid Padding="15,12" BorderThickness="0,0,0,1" BorderBrush="#3F3F46">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.6*"/>
                                        <ColumnDefinition Width="1.4*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1.4*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{x:Bind Id}" Foreground="#888888" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{x:Bind FlightNumber}" Foreground="#E0E0E0" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{x:Bind FlightType}" Foreground="#E0E0E0" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{x:Bind Date}" Foreground="#E0E0E0" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="{x:Bind GateName}" Foreground="#E0E0E0" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="5" Text="{x:Bind RunwayName}" Foreground="#E0E0E0" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="6" Text="{x:Bind FlightTime}" Foreground="{StaticResource CustomAccentBrush}" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <TextBlock x:Name="EmptyStateText"
                               Text="This employee has no scheduled flights."
                               Foreground="#A0A0A0"
                               FontSize="18"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>