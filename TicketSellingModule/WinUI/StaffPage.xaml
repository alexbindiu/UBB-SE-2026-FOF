<Page
    x:Class="TicketSellingModule.WinUI.StaffPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TicketSellingModule.WinUI"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#1E1E1E">
    <Page.Resources>
        <SolidColorBrush x:Key="CustomAccentBrush" Color="#2bb8c0"/>
    </Page.Resources>

    <Grid Padding="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,40" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <FontIcon Grid.Column="0" Glyph="&#xE709;" FontSize="32" Foreground="{StaticResource CustomAccentBrush}" HorizontalAlignment="Left"/>

            <TextBlock Grid.Column="1" Text="CAPTAIN SAM SMITH" FontSize="26" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>

            <Border Grid.Column="2" Width="50" Height="50" CornerRadius="25" Background="{StaticResource CustomAccentBrush}" HorizontalAlignment="Right">
                <TextBlock Text="P" FontSize="24" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <Border Grid.ColumnSpan="3" BorderThickness="0,0,0,1" BorderBrush="#333333" VerticalAlignment="Bottom" Margin="0,0,0,-15"/>
        </Grid>

        <Border Grid.Row="1" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="8" HorizontalAlignment="Center" VerticalAlignment="Top" Width="850" Height="550" Background="#252526">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="FLIGHTS: WEDNESDAY, MARCH 25" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="20"/>

                <Grid Grid.Row="1" Background="{StaticResource CustomAccentBrush}" Padding="15,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1.5*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="FLIGHT NO." Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="TYPE (Arr/Dep)" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="GATE" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="RUNWAY" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="TIME" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </Grid>

                <ListView Grid.Row="2" x:Name="FlightScheduleList" Padding="0" BorderThickness="0">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="15,12" BorderThickness="0,0,0,1" BorderBrush="#3F3F46">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding FlightNumber}" FontSize="16" HorizontalAlignment="Center" Foreground="#E0E0E0"/>
                                <TextBlock Grid.Column="1" Text="{Binding FlightType}" FontSize="16" HorizontalAlignment="Center" Foreground="#E0E0E0"/>
                                <TextBlock Grid.Column="2" Text="{Binding GateName}" FontSize="16" HorizontalAlignment="Center" Foreground="#E0E0E0"/>
                                <TextBlock Grid.Column="3" Text="{Binding RunwayName}" FontSize="16" HorizontalAlignment="Center" Foreground="#E0E0E0"/>
                                <TextBlock Grid.Column="4" Text="{Binding FlightTime}" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{StaticResource CustomAccentBrush}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Grid Grid.Row="3" BorderThickness="0,1,0,0" BorderBrush="#3F3F46" Padding="15,15" Background="#1E1E1E">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="&#xE760; Previous Day" FontFamily="Segoe UI Variable" Background="#333337" Foreground="White" FontWeight="Medium" VerticalAlignment="Center" Padding="15,8" CornerRadius="4"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
                        <FontIcon Glyph="&#xE787;" FontSize="24" Foreground="#888888"/>
                    </StackPanel>

                    <Button Grid.Column="2" Content="Next Day &#xE761;" FontFamily="Segoe UI Variable" Background="#333337" Foreground="White" FontWeight="Medium" VerticalAlignment="Center" Padding="15,8" CornerRadius="4"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>