<Page
    x:Class="TicketSellingModule.WinUI.CompanyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TicketSellingModule.WinUI"
    xmlns:domain="using:TicketSellingModule.Domain"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#1E1E1E">

    <Page.Resources>
        <SolidColorBrush x:Key="CustomAccentBrush" Color="#2bb8c0"/>
    </Page.Resources>

    <Grid Padding="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <ContentDialog x:Name="AddFlightDialog"
                       Title="ADD FLIGHT"
                       PrimaryButtonText="Save Flight"
                       CloseButtonText="Cancel"
                       DefaultButton="Primary"
                       Background="#252526"
                       RequestedTheme="Dark">

            <StackPanel Spacing="15" Width="450">
                <Grid ColumnSpacing="20" RowSpacing="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox x:Name="TypeComboBox" Header="TYPE" PlaceholderText="Arr / Dep" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Stretch">
                        <x:String>Arrival</x:String>
                        <x:String>Departure</x:String>
                    </ComboBox>

                    <ComboBox x:Name="AirportComboBox" Header="AIRPORT" PlaceholderText="Select Airport" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Stretch" 
                              ItemsSource="{x:Bind ViewModel.AirportsList}" DisplayMemberPath="AirportName"/>

                    <TimePicker x:Name="DepTimePicker" Header="DEP. TIME" Grid.Row="1" Grid.Column="0" HorizontalAlignment="Stretch"/>
                    <TimePicker x:Name="ArrTimePicker" Header="ARR. TIME" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch"/>

                    <TextBox x:Name="CapacityTextBox" Header="CAPACITY" PlaceholderText="e.g. 180" Grid.Row="2" Grid.Column="0"/>
                    <CheckBox x:Name="RecurrentCheckBox" Content="Recurrent Flight" Grid.Row="2" Grid.Column="1" VerticalAlignment="Bottom" 
                              Checked="RecurrentCheckBox_Checked" Unchecked="RecurrentCheckBox_Unchecked"/>

                    <CalendarDatePicker x:Name="SingleDatePicker" Header="DATE" Grid.Row="3" Grid.Column="0" HorizontalAlignment="Stretch"/>
                </Grid>

                <StackPanel x:Name="RecurrentPanel" Visibility="Collapsed" Spacing="15" Margin="0,10,0,0" Padding="15" Background="#1E1E1E" CornerRadius="8">
                    <ComboBox x:Name="RecurrenceTypeComboBox" Header="Recurrence Type" HorizontalAlignment="Stretch" SelectionChanged="RecurrenceTypeComboBox_SelectionChanged">
                        <x:String>Daily</x:String>
                        <x:String>Weekly</x:String>
                        <x:String>Monthly</x:String>
                        <x:String>Custom</x:String>
                    </ComboBox>

                    <TextBox x:Name="CustomDaysTextBox" Header="Every [ ] days" PlaceholderText="e.g. 3" Visibility="Collapsed" Width="150" HorizontalAlignment="Left"/>

                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <CalendarDatePicker x:Name="StartDatePicker" Header="START DATE" Grid.Column="0" HorizontalAlignment="Stretch"/>
                        <CalendarDatePicker x:Name="EndDatePicker" Header="END DATE" Grid.Column="1" HorizontalAlignment="Stretch"/>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </ContentDialog>


        <Grid Grid.Row="0" Margin="0,0,0,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <FontIcon Grid.Column="0" Glyph="&#xE709;" FontSize="32" Foreground="{StaticResource CustomAccentBrush}"/>
            <TextBlock Grid.Column="1" Text="WIZZ AIR DASHBOARD" FontSize="26" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
            <Border Grid.Column="2" Width="50" Height="50" CornerRadius="25" Background="{StaticResource CustomAccentBrush}">
                <TextBlock Text="C" FontSize="24" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <Border Grid.ColumnSpan="3" BorderThickness="0,0,0,1" BorderBrush="#333333" VerticalAlignment="Bottom" Margin="0,0,0,-15"/>
        </Grid>

        <Border Grid.Row="1" BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="8" Background="#252526" Width="900" HorizontalAlignment="Center" VerticalAlignment="Top" Height="600">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="20,20,20,10">
                    <TextBlock Text="COMPANY'S FLIGHTS" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Button Content="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="20" Background="{StaticResource CustomAccentBrush}" Foreground="White" 
                            HorizontalAlignment="Right" Width="40" Height="40" CornerRadius="4" Click="AddFlightButton_Click"/>
                </Grid>

                <TextBox x:Name="SearchTextBox" 
         TextChanged="SearchTextBox_TextChanged" 
         Grid.Row="1" 
         PlaceholderText="Search flights by flight number..." 
         Margin="20,0,20,15" 
         Width="400" 
         HorizontalAlignment="Center" 
         Background="#1E1E1E" 
         Foreground="White" 
         BorderThickness="1" 
         BorderBrush="#3F3F46"/>
                <Grid Grid.Row="2" Background="{StaticResource CustomAccentBrush}" Padding="15,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.5*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="0.5*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="ID" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="FLIGHT NO." Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="ROUTE" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="DATE" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="GATE" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </Grid>

                <ListView x:Name="FlightsListView" Grid.Row="3" ItemsSource="{x:Bind ViewModel.CompanyFlightsList, Mode=OneWay}" Padding="0" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="domain:Flight">
                            <Grid Padding="15,12" BorderThickness="0,0,0,1" BorderBrush="#3F3F46">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="0.5*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="0.5*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{x:Bind Id}" FontSize="14" HorizontalAlignment="Center" Foreground="#888888"/>
                                <TextBlock Grid.Column="1" Text="{x:Bind FlightNumber}" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#E0E0E0"/>
                                <TextBlock Grid.Column="2" Text="{x:Bind RouteId}" FontSize="14" HorizontalAlignment="Center" Foreground="#E0E0E0"/>
                                <TextBlock Grid.Column="3" Text="{x:Bind Date}" FontSize="14" HorizontalAlignment="Center" Foreground="#E0E0E0"/>
                                <TextBlock Grid.Column="4" Text="{x:Bind GateId}" FontSize="14" HorizontalAlignment="Center" Foreground="#E0E0E0"/>
                                <Button Grid.Column="5" 
                                    Content="&#xE711;" 
                                    FontFamily="Segoe MDL2 Assets" 
                                    Background="Transparent" 
                                    Foreground="#FF5555" 
                                    HorizontalAlignment="Center" 
                                    VerticalAlignment="Center"
                                    Tag="{x:Bind Id}"
                                    Click="DeleteFlightButton_Click" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Page>