<Page
    x:Class="TicketSellingModule.WinUI.SelectCompanyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#0F172A">

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
        <TextBlock Text="SELECT YOUR AIRLINE" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>

        
        <ComboBox x:Name="CompaniesComboBox" Width="300" PlaceholderText="Choose a company..."
                  DisplayMemberPath="Name" Background="#252526" Foreground="White"/>

        <Button Content="Go to Dashboard" Width="300" Height="40" Background="#2bb8c0" Foreground="White" FontWeight="Bold"
                Click="GoButton_Click"/>
    </StackPanel>
</Page>