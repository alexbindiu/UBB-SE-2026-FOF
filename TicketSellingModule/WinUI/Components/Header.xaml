<UserControl
    x:Class="TicketSellingModule.WinUI.Components.Header"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TicketSellingModule.WinUI.Components">

    <UserControl.Resources>
        <SolidColorBrush x:Key="CustomAccentBrush" Color="#2bb8c0"/>
    </UserControl.Resources>
    
    <Grid Margin="0,0,0,30">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Button Grid.Column="0"
            Click="BackButton_Click"
            Background="Transparent"
            BorderThickness="0"
            Padding="0"
            Width="48"
            Height="48"
            HorizontalAlignment="Left"
            VerticalAlignment="Center"
            ToolTipService.ToolTip="Home">
            <FontIcon Glyph="&#xE80F;" FontSize="28" Foreground="White"/>
        </Button>

        <StackPanel Grid.Column="1"
            Orientation="Horizontal"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="10">
            <FontIcon Glyph="&#xE709;"
              FontSize="32"
              Foreground="{StaticResource CustomAccentBrush}"
              VerticalAlignment="Center"/>
            <TextBlock Text="Flight Module"
               FontSize="26"
               FontWeight="SemiBold"
               Foreground="White"
               VerticalAlignment="Center"/>
        </StackPanel>

        <Border Grid.Column="2"
                Width="50"
                Height="50"
                CornerRadius="25"
                Background="{StaticResource CustomAccentBrush}"
                HorizontalAlignment="Right"
                VerticalAlignment="Center">
            <FontIcon Glyph="&#xE77B;" FontSize="28" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
        <Border Grid.ColumnSpan="3" BorderThickness="0,0,0,1" BorderBrush="#333333" VerticalAlignment="Bottom" Margin="0,0,0,-15"/>
    </Grid>
</UserControl>