<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TicketSellingModule.WinUI.AirportAdmin.EmployeesDashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:TicketSellingModule.WinUI.AirportAdmin.Components"
    mc:Ignorable="d"
    Foreground="#F8FAFC">

    <ScrollViewer>
        <Grid Padding="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Employees Dashboard"
                       FontSize="24"
                       FontWeight="SemiBold"/>

            <local:EmployeeSectionControl Grid.Row="2"
                                          x:Name="AirTrafficSection"
                                          SectionTitle="Air Traffic"/>

            <local:EmployeeSectionControl Grid.Row="4"
                                          x:Name="FlightDispatchersSection"
                                          SectionTitle="Flight Dispatcher"/>

            <local:EmployeeSectionControl Grid.Row="6"
                                          x:Name="GroundHandlersSection"
                                          SectionTitle="Ground Handler"/>
            
            <local:EmployeeSectionControl Grid.Row="8"
                                          x:Name="EngineersSection"
                                          SectionTitle="Engineer"/>
        </Grid>
    </ScrollViewer>
</Page>
