<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TicketSellingModule.WinUI.AirportAdmin.FlightsDashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:TicketSellingModule.WinUI.AirportAdmin.Components"
    mc:Ignorable="d"
    Foreground="#F8FAFC">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <AutoSuggestBox x:Name="FlightSearchBox"
                            PlaceholderText="Search flights..."
                            QuerySubmitted="FlightSearchBox_QuerySubmitted"
                            TextChanged="FlightSearchBox_TextChanged"/>

            <Button Grid.Column="2"
                    Content="Refresh"
                    Click="RefreshButton_Click"/>

            <Button Grid.Column="4"
                Content="Manage Crew"
                Style="{StaticResource AccentButtonStyle}"
                Click="AssignCrewButton_Click"/>
            
        </Grid>

        <local:FlightListControl Grid.Row="2"
                                  x:Name="FlightListControl"
                                  Items="{x:Bind FilteredFlights, Mode=OneWay}"/>
    </Grid>
</Page>
