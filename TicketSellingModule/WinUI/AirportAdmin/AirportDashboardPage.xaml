<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TicketSellingModule.WinUI.AirportAdmin.AirportDashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TicketSellingModule.WinUI.AirportAdmin.Components"
    Foreground="#F8FAFC">

    <ScrollViewer>
        <Grid Padding="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <local:AirportSectionControl Grid.Column="0"
                                         x:Name="RunwaysSection"
                                         Title="Runways"
                                         Items="{Binding RunwaysList}"
                                         SelectedItem="{Binding SelectedRunway, Mode=TwoWay}"
                                         AddCommand="{Binding AddRunwayCommand}"
                                         EditCommand="{Binding UpdateRunwayCommand}"
                                         DeleteCommand="{Binding DeleteRunwayCommand}" />

            <local:AirportSectionControl Grid.Column="2"
                                         x:Name="GatesSection"
                                         Title="Gates"
                                         Items="{Binding GatesList}"
                                         SelectedItem="{Binding SelectedGate, Mode=TwoWay}"
                                         AddCommand="{Binding AddGateCommand}"
                                         EditCommand="{Binding UpdateGateCommand}"
                                         DeleteCommand="{Binding DeleteGateCommand}" />

            <local:AirportSectionControl Grid.Column="4"
                                         x:Name="AirportsSection"
                                         Title="Destination Airports"
                                         Items="{Binding AirportsList}"
                                         SelectedItem="{Binding SelectedAirport, Mode=TwoWay}"
                                         AddCommand="{Binding AddAirportCommand}"
                                         EditCommand="{Binding UpdateAirportCommand}"
                                         DeleteCommand="{Binding DeleteAirportCommand}" />
        </Grid>
    </ScrollViewer>
</Page>