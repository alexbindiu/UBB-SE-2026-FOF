<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="TicketSellingModule.WinUI.AirportAdmin.EmployeesDashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:TicketSellingModule.WinUI.AirportAdmin.Components"
    mc:Ignorable="d"
    Foreground="#F8FAFC">

    <ScrollViewer>
        <Grid Padding="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- TODO MVVM: host the ContentDialog here and bind its visibility/content to the ViewModel dialog properties. -->
            <TextBlock Text="Employees Dashboard"
                       FontSize="24"
                       FontWeight="SemiBold"/>

            <local:EmployeeSectionControl Grid.Row="2"
                                          SectionTitle="Pilot"
                                          ItemsSource="{x:Bind ViewModel.PilotEmployees, Mode=OneWay}"
                                          AddCommand="{x:Bind ViewModel.AddEmployeeCommand}"
                                          EditCommand="{x:Bind ViewModel.EditEmployeeCommand}"
                                          DeleteCommand="{x:Bind ViewModel.DeleteEmployeeCommand}" />

            <local:EmployeeSectionControl Grid.Row="4"
                                          SectionTitle="Flight Attendant"
                                          ItemsSource="{x:Bind ViewModel.FlightAttendantEmployees, Mode=OneWay}"
                                          AddCommand="{x:Bind ViewModel.AddEmployeeCommand}"
                                          EditCommand="{x:Bind ViewModel.EditEmployeeCommand}"
                                          DeleteCommand="{x:Bind ViewModel.DeleteEmployeeCommand}" />

            <local:EmployeeSectionControl Grid.Row="6"
                                          SectionTitle="Co-Pilot"
                                          ItemsSource="{x:Bind ViewModel.CoPilotEmployees, Mode=OneWay}"
                                          AddCommand="{x:Bind ViewModel.AddEmployeeCommand}"
                                          EditCommand="{x:Bind ViewModel.EditEmployeeCommand}"
                                          DeleteCommand="{x:Bind ViewModel.DeleteEmployeeCommand}" />
            
            <local:EmployeeSectionControl Grid.Row="8"
                                          SectionTitle="Flight Dispatcher"
                                          ItemsSource="{x:Bind ViewModel.FlightDispatcherEmployees, Mode=OneWay}"
                                          AddCommand="{x:Bind ViewModel.AddEmployeeCommand}"
                                          EditCommand="{x:Bind ViewModel.EditEmployeeCommand}"
                                          DeleteCommand="{x:Bind ViewModel.DeleteEmployeeCommand}" />

            <Grid Grid.RowSpan="9" 
              Background="#80000000" 
              Visibility="{x:Bind ViewModel.DialogVisibility, Mode=OneWay}"
              CornerRadius="8">
            
            <Border Background="#1E293B" 
                    BorderBrush="#334155" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Padding="24"
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    Width="350">
                
                <StackPanel Spacing="16">
                    <TextBlock Text="{x:Bind ViewModel.DialogTitle, Mode=OneWay}" 
                               FontSize="20" FontWeight="Bold" Foreground="White"/>

                    <TextBox Header="Role" 
                             Text="{x:Bind ViewModel.EditingEmployee.Role, Mode=OneWay}" 
                             IsReadOnly="True" />

                    <TextBox Header="Name" 
                             Text="{x:Bind ViewModel.EditingEmployee.Name, Mode=TwoWay}" 
                             PlaceholderText="Enter employee name"/>

                    <TextBox Header="Salary" 
                             Text="{x:Bind ViewModel.EditingSalaryText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                             PlaceholderText="Enter salary"/>

                    <CalendarDatePicker Header="Birthday" 
                                        Date="{x:Bind ViewModel.EditingBirthday, Mode=TwoWay}" 
                                        HorizontalAlignment="Stretch"/>

                    <CalendarDatePicker Header="Hiring Date" 
                                        Date="{x:Bind ViewModel.EditingHiringDate, Mode=TwoWay}" 
                                        HorizontalAlignment="Stretch"/>

                    <TextBlock Text="{x:Bind ViewModel.DialogErrorMessage, Mode=OneWay}"
                               Foreground="#FF6B6B" 
                               TextWrapping="Wrap"
                               FontWeight="SemiBold"
                               Margin="0,-4,0,0"/>

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
        
                        <Button Content="Cancel" 
                                HorizontalAlignment="Stretch"
                                Command="{x:Bind ViewModel.CloseDialogCommand}"/>
                
                        <Button Grid.Column="2" 
                                Content="Save" 
                                Style="{StaticResource AccentButtonStyle}"
                                HorizontalAlignment="Stretch"
                                Command="{x:Bind ViewModel.SaveEmployeeCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid></Grid>
    </ScrollViewer>
</Page>
